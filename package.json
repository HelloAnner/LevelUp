    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.7.0",
    "eslint": "^9",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.1.0"
  }
}
